# Copy to .env and fill with your values. Never commit .env to git.
# See .gitignore ( .env is ignored ).

# Supabase (frontend – safe to expose in client; RLS protects data)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Stripe: do NOT put any Stripe key here. Stripe secret key (sk_...) is only
# set in Supabase Edge Function secrets (Dashboard → Edge Functions → Secrets).
# The frontend never sees Stripe secret keys.
